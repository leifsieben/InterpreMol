{
  "loss": "typed-multitask",
  "task_manifest_include_flag": "include_in_hpo",
  "streaming": true,
  "use_amp": false,
  "num_workers": 0,
  "pin_memory": true,
  "d_model": 128,
  "n_layers": 2,
  "n_heads": 4,
  "dim_ff": 256,
  "mlp_hidden_dim": 128,
  "mlp_head_depth": 2,
  "max_distance": 4,
  "max_atoms": 96,
  "batch_size": 8,
  "grad_accum_steps": 1,
  "epochs": 3,
  "warmup_epochs": 1,
  "early_stopping_patience": 2,
  "checkpoint_every": 1,
  "keep_last_n": 2,
  "log_every": 20,
  "max_val_batches": 20,
  "min_val_group_count": 1,
  "enforce_val_group_coverage": true
}
